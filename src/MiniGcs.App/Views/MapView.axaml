<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MiniGcs.App.ViewModels"
             xmlns:views="using:MiniGcs.App.Views"
             x:Class="MiniGcs.App.Views.MapView"
             x:DataType="vm:MapViewModel">
    
    <Grid>
        <!-- карта -->
        <views:MapCanvas x:Name="TheMapCanvas" />
        
        <!-- Панель управления -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Right" 
                Background="#2A2A3E" CornerRadius="5" Padding="10" Margin="10"
                Opacity="0.9">
            <StackPanel Spacing="5">
                <Button Content="+" Click="ZoomIn_Click" 
                       Background="#50FA7B" Foreground="#282A36"
                       Width="40" Height="40" FontSize="16" FontWeight="Bold"/>
                <Button Content="-" Click="ZoomOut_Click"
                       Background="#50FA7B" Foreground="#282A36"
                       Width="40" Height="40" FontSize="16" FontWeight="Bold"/>
                <Button Content="*" Click="CenterOnDrone_Click"
                       Background="#8BE9FD" Foreground="#282A36"
                       Width="40" Height="40" FontSize="16"/>
                <Button Content="A" Click="ToggleAutoCenter_Click"
                       Background="#FF79C6" Foreground="#282A36"
                       Width="40" Height="40" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <!-- Информация -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" 
                Background="#2A2A3E" CornerRadius="5" Padding="10" Margin="10"
                Opacity="0.9">
            <StackPanel>
                <TextBlock Text="КАРТА (Avalonia Canvas)" 
                          Foreground="#8BE9FD" FontWeight="Bold" FontSize="12"/>
                <TextBlock Text="{Binding CenterLat, StringFormat='Center Lat: {0:F6}'}" 
                          Foreground="#F8F8F2" FontSize="11"/>
                <TextBlock Text="{Binding CenterLon, StringFormat='Center Lon: {0:F6}'}" 
                          Foreground="#F8F8F2" FontSize="11"/>
                <TextBlock Text="{Binding ZoomLevel, StringFormat='Zoom: {0}'}" 
                          Foreground="#F8F8F2" FontSize="11"/>
                <TextBlock Text="{Binding AutoCenterOnDrone, StringFormat='Автоцентр: {0}'}" 
                          Foreground="#F1FA8C" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>